use flake

# Pin state directory under the project (keep $HOME clean)
export COMFYUI_STATE_DIR="$PWD/.comfyui-state"

# CUDA driver libs (NixOS)
export LD_LIBRARY_PATH="/run/opengl-driver/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
[ -d /run/opengl-driver-32/lib ] && export LD_LIBRARY_PATH="/run/opengl-driver-32/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
